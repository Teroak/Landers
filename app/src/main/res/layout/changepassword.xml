<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Red Header -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#1FDD0A"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Change Password"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Info text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your new password must be different from your previously used password."
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginBottom="24dp"/>

        <!-- Current Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current Password"
            android:textSize="13sp"
            android:textColor="#444444"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/edit_current_password"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Enter current password"
            android:background="@drawable/edit_text_border"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:layout_marginBottom="16dp"/>

        <!-- New Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="New Password"
            android:textSize="13sp"
            android:textColor="#444444"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/edit_new_password"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Enter new password"
            android:background="@drawable/edit_text_border"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Must be at least 8 characters"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <!-- Confirm New Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirm New Password"
            android:textSize="13sp"
            android:textColor="#444444"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/edit_confirm_new_password"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Re-enter new password"
            android:background="@drawable/edit_text_border"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:layout_marginBottom="32dp"/>

        <!-- Save Button -->
        <Button
            android:id="@+id/button_save_password"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="SAVE CHANGES"
            android:backgroundTint="#1FDD0A"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp"/>

    </LinearLayout>
</LinearLayout>