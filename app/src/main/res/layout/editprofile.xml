<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Red Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="#1FDD0A"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edit Profile"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- First Name -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="First Name"
                android:textSize="13sp"
                android:textColor="#444444"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <!-- Last Name -->
            <EditText
                android:id="@+id/edit_first_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edit_text_border"
                android:hint="First name"
                android:inputType="textPersonName"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Juan" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last Name"
                android:textSize="13sp"
                android:textColor="#444444"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/edit_last_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Last name"
                android:text="Dela Cruz"
                android:background="@drawable/edit_text_border"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"/>

            <!-- Email (read-only) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textSize="13sp"
                android:textColor="#444444"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/edit_email"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="juan@email.com"
                android:background="@drawable/edit_text_border_disabled"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:enabled="false"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="6dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email cannot be changed"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="16dp"/>

            <!-- Mobile -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mobile Number"
                android:textSize="13sp"
                android:textColor="#444444"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/edit_mobile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="+63"
                android:text="+63 912 345 6789"
                android:background="@drawable/edit_text_border"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="phone"
                android:layout_marginBottom="16dp"/>

            <!-- Birthday -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Birthday"
                android:textSize="13sp"
                android:textColor="#444444"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/edit_birthday"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="MM/DD/YYYY"
                android:text="01/01/1990"
                android:background="@drawable/edit_text_border"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="date"
                android:layout_marginBottom="16dp"/>

            <!-- Gender -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gender"
                android:textSize="13sp"
                android:textColor="#444444"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <RadioGroup
                android:id="@+id/radio_gender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <RadioButton
                    android:id="@+id/radio_male"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Male"
                    android:textColor="#444444"
                    android:buttonTint="#1FDD0A"
                    android:checked="true"
                    android:layout_marginEnd="24dp"/>

                <RadioButton
                    android:id="@+id/radio_female"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Female"
                    android:textColor="#444444"
                    android:buttonTint="#1FDD0A"
                    android:layout_marginEnd="24dp"/>

                <RadioButton
                    android:id="@+id/radio_other"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Other"
                    android:textColor="#444444"
                    android:buttonTint="#1FDD0A"/>
            </RadioGroup>

            <!-- Save Button -->
            <Button
                android:id="@+id/button_save_profile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="SAVE CHANGES"
                android:backgroundTint="#1FDD0A"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <!-- Cancel -->
            <Button
                android:id="@+id/button_cancel"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CANCEL"
                android:backgroundTint="#FFFFFF"
                android:textColor="#888888"
                android:textStyle="bold"
                android:textSize="15sp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>